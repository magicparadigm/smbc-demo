# DocuSign Developer Sandbox Credentials
# Obtain these from https://developers.docusign.com after creating a free developer account

# Your DocuSign Integration Key (Client ID) from the app you created
DS_CLIENT_ID=your-integration-key-here

# Your DocuSign User ID (GUID) — found in your developer account profile
DS_USER_ID=your-user-id-guid-here

# Your DocuSign Account ID (GUID) — shown in your developer account
DS_ACCOUNT_ID=your-account-id-guid-here

# Path to the RSA private key file downloaded from your DocuSign app settings
# Generate a key pair in your DocuSign app → "Authentication" → "Add RSA Keypair"
DS_PRIVATE_KEY_PATH=./private.key

# DocuSign Template ID — create a template in your sandbox account and paste its ID here
DS_TEMPLATE_ID=your-template-id-here

# Role names must exactly match the role names defined in your DocuSign template
DS_SIGNER1_ROLE=Signer 1
DS_SIGNER2_ROLE=Signer 2

# Port for the local Express server
PORT=3000
